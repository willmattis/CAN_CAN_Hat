CM_ BU_ INV "The Cascadia Motion inverter";
CM_ BU_ U2C "Delphi DC/DC Converter";
CM_ BU_ VCU "The system vehicle control unit";
CM_ BU_ BMS "BMS Master";
CM_ SG_ 221 INV_Iq_Command "The commanded Q-axis current";
CM_ SG_ 221 INV_Id_Command "The commanded D-axis current";
CM_ SG_ 221 INV_Flux_Weakening_Output "This is the current output of the flux regulator.";
CM_ SG_ 221 INV_Modulation_Index "This is the modulation index. The scale factor is x100. To get the actual modulation index divide the value by 100.";
CM_ SG_ 220 INV_Power_On_Timer "Updated every 3 msec. This will roll over in approximately 150 days!";
CM_ SG_ 220 INV_Torque_Feedback "Estimated motor torque feedback";
CM_ SG_ 220 INV_Commanded_Torque "The commanded Torque";
CM_ BO_ 242 "The inverter response to each Parameter message that is received.";
CM_ SG_ 242 INV_Write_Success "0=Write failure, 1=Success";
CM_ SG_ 242 INV_Data_Response "All EEPROM data is 16 bits and is contained in bytes 4 and 5. Bytes 6 and 7 should be ignored.";
CM_ SG_ 242 INV_Parameter_Address_Response "Valid EEPROM Parameter CAN addresses are between 100 and 499.";
CM_ BO_ 241 "Parameter Message sent as needed by VCU to request info, change EEPROM, or command a function.";
CM_ BO_ 240 "The command message is used to transmit data to the controller. This message is sent from a user supplied external controller to the PMxxx controller.";
CM_ SG_ 219 INV_Run_Fault_Hi "Each bit represents a fault. Please refer to PM100 Users Manual for details.";
CM_ SG_ 219 INV_Post_Fault_Hi "Each bit represents a fault. Please refer to PM100 Users Manual for details.";
CM_ SG_ 219 INV_Run_Fault_Lo "Each bit represents a fault. Please refer to PM100 Users Manual for details.";
CM_ SG_ 219 INV_Post_Fault_Lo "Each bit represents a fault. Please refer to PM100 Users Manual for details.";
