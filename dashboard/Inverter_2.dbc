0 = 'Reverse' if inverter enabled  & 'Stopped' if inverter is disabled";
CM_ SG_ 218 INV_Inverter_Enable_State "0=Inverter Disabled, 
1=Inverter Enabled";
CM_ SG_ 218 INV_Relay_3_Status "0=OFF, 1=ON";
CM_ SG_ 218 INV_Relay_4_Status "0=OFF, 1=ON";
CM_ SG_ 218 INV_Relay_2_Status "0=OFF, 1=ON";
CM_ SG_ 218 INV_Inverter_Run_Mode "0=Torque Mode, 1=Speed Mode";
CM_ SG_ 218 INV_Inverter_Command_Mode "0=CAN mode, 1=VSM mode";
CM_ SG_ 218 INV_Relay_1_Status "0=OFF, 1=ON";
CM_ SG_ 218 INV_Inverter_State "Different states for the inverter state machine";
CM_ SG_ 218 INV_VSM_State "Different states for the vehicle state machine";
CM_ SG_ 218 INV_Inverter_Enable_Lockout "0=Lockout Disabled, 1=Lockout Enabled";
CM_ SG_ 218 INV_Inverter_Discharge_State "0 = Disabled, 1 = Enabled, 2 = Speed Check, 3 = Active, 4 = Complete";
CM_ SG_ 218 INV_Relay_5_Status "0=OFF, 1=ON";
CM_ SG_ 218 INV_Relay_6_Status "0=OFF, 1=ON";
CM_ SG_ 218 INV_BMS_Active "0 = BMS Not Active, 1 = BMS Active";
CM_ SG_ 218 INV_BMS_Torque_Limiting "0 = Not Limiting, 1 = Limiting";
CM_ SG_ 218 INV_Max_Speed_Limiting "0 = Not Limiting, 1 = torque limiting due to maximum speed";
CM_ SG_ 218 INV_Low_Speed_Limiting "0 = Not Limiting, 1 = Current limiting due to low motor speed";
CM_ SG_ 218 INV_Rolling_Counter "The current rolling counter value.";
CM_ SG_ 218 INV_PWM_Frequency "The inverter PWM frequency";
CM_ SG_ 218 INV_Start_Mode_Active "If in Key Switch Mode 1 then indicates status of Start input being applied.  0 = not active, 1 = active";
